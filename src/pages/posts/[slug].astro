---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('posts', slug);

if (!post) {
  throw new Error(`Post not found for slug: ${slug}`);
}

const { Content } = await post.render();
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="post">
    <a href="/" class="back-link">← back</a>

    <header class="post-header">
      {post.data.category && <span class="post-category">{post.data.category}</span>}
      <h1>{post.data.title}</h1>
      {post.data.date && (
        <p class="post-date">{post.data.date.toDateString()}</p>
      )}
    </header>

    <div class="post-body">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .post {
    max-width: 720px;
    margin: 4rem auto;
    padding: 0 1.5rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--yellow);
    margin-bottom: 2rem;
    border-bottom: 1px dashed transparent;
    transition: border-color 0.2s;
  }

  .back-link:hover {
    border-color: var(--yellow);
  }

  .post-header {
    border-bottom: 1px solid #333;
    padding-bottom: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .post-category {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--yellow);
    border: 1px solid var(--yellow);
    padding: 0.2em 0.6em;
    margin-bottom: 0.75rem;
  }

  h1 {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: var(--white);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #666;
    margin: 0.25rem 0 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Prose content — needs :global() because Content renders outside scope */
  .post-body :global(p) {
    line-height: 1.8;
    margin: 1.25rem 0;
    color: #ccc;
  }

  .post-body :global(h2) {
    font-family: var(--font-mono);
    font-size: 1.35rem;
    margin: 2.5rem 0 1rem;
    color: var(--white);
    border-bottom: 1px solid #333;
    padding-bottom: 0.5rem;
  }

  .post-body :global(h3) {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    margin: 2rem 0 0.75rem;
    color: var(--yellow);
  }

  .post-body :global(h4),
  .post-body :global(h5),
  .post-body :global(h6) {
    font-family: var(--font-mono);
    margin: 1.5rem 0 0.5rem;
    color: #aaa;
  }

  .post-body :global(a) {
    color: var(--yellow);
    border-bottom: 1px dashed var(--yellow);
    transition: opacity 0.2s;
  }

  .post-body :global(a:hover) {
    opacity: 0.75;
  }

  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: #1a1a1f;
    border: 1px solid #333;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    color: #9cdcfe;
  }

  .post-body :global(pre) {
    background: #1a1a1f;
    border: 1px solid #333;
    border-left: 3px solid var(--yellow);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.75rem 0;
  }

  .post-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: #d4d4d4;
    font-size: 0.875rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--yellow);
    margin: 1.75rem 0;
    padding: 0.25rem 1.25rem;
    color: #999;
    font-style: italic;
  }

  .post-body :global(blockquote p) {
    color: #999;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin: 1rem 0;
    color: #ccc;
  }

  .post-body :global(li) {
    line-height: 1.8;
    margin: 0.3rem 0;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid #333;
    margin: 2.5rem 0;
  }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid #333;
    display: block;
    margin: 1.5rem 0;
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    margin: 1.5rem 0;
  }

  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid #333;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .post-body :global(th) {
    background: #1a1a1f;
    color: var(--yellow);
  }
</style>
